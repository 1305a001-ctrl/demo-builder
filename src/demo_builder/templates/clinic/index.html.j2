<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ name }} — {{ city or "Malaysia" }}</title>
  <meta name="description" content="{{ tagline }}" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --primary: {{ primary_color }};
      --accent:  {{ accent_color }};
    }
    body { font-family: 'Inter', system-ui, sans-serif; color: #0f172a; }
    .bg-primary { background: var(--primary); }
    .text-primary { color: var(--primary); }
    .bg-accent { background: var(--accent); }
    .text-accent { color: var(--accent); }
    .border-primary { border-color: var(--primary); }
  </style>
</head>
<body class="bg-white">

<!-- Demo banner -->
<div class="bg-amber-100 border-b border-amber-300 text-amber-900 text-center text-xs py-1.5 px-4">
  ✨ This is a demo built for {{ name }}. To make it real, get in touch.
</div>

<!-- Top nav (single page) -->
<nav class="border-b border-slate-200 bg-white sticky top-0 z-10">
  <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
    <span class="font-bold text-lg text-primary">{{ name }}</span>
    <div class="hidden md:flex gap-6 text-sm">
      <a href="#services" class="hover:text-primary">Services</a>
      <a href="#about" class="hover:text-primary">About</a>
      <a href="#visit" class="hover:text-primary">Visit</a>
      <a href="{{ booking_url }}" class="bg-primary text-white px-4 py-1.5 rounded-md font-medium hover:opacity-90">Book online</a>
    </div>
  </div>
</nav>

<!-- Hero -->
<header class="relative overflow-hidden">
  <img src="{{ hero_image }}" alt="{{ name }}" class="absolute inset-0 w-full h-full object-cover opacity-20" />
  <div class="absolute inset-0 bg-gradient-to-r from-white via-white/95 to-transparent"></div>
  <div class="relative max-w-6xl mx-auto px-6 py-24 md:py-32">
    <p class="uppercase tracking-widest text-xs text-accent font-semibold mb-3">{{ city or "Malaysia" }}</p>
    <h1 class="text-5xl md:text-6xl font-bold mb-5 max-w-2xl text-slate-900">{{ name }}</h1>
    <p class="text-lg md:text-xl text-slate-600 max-w-xl mb-8">{{ tagline }}</p>
    <div class="flex flex-wrap gap-3">
      <a href="{{ booking_url }}" class="bg-primary hover:opacity-90 text-white px-6 py-3 rounded-lg font-semibold">Book an appointment</a>
      <a href="#services" class="border border-slate-300 hover:border-primary text-slate-800 px-6 py-3 rounded-lg font-semibold">See our services</a>
    </div>
  </div>
</header>

<!-- Trust strip -->
<section class="bg-slate-50 border-y border-slate-200 py-6">
  <div class="max-w-6xl mx-auto px-6 flex flex-wrap items-center gap-6">
    {% if rating %}
    <div class="flex items-center gap-2">
      <span class="text-2xl text-accent">★</span>
      <span class="text-xl font-semibold">{{ "%.1f" % rating }}</span>
      <span class="text-sm text-slate-500">Google</span>
    </div>
    {% endif %}
    {% if review_count %}
    <div class="text-sm text-slate-600"><span class="font-semibold text-slate-900">{{ "{:,}".format(review_count) }}</span> patient reviews</div>
    {% endif %}
    <div class="text-sm text-slate-600">✓ Walk-ins welcome</div>
    <div class="text-sm text-slate-600">✓ Online booking</div>
  </div>
</section>

<!-- Services -->
<section id="services" class="max-w-6xl mx-auto px-6 py-20">
  <h2 class="text-3xl md:text-4xl font-bold mb-3 text-primary">What we do</h2>
  <p class="text-slate-600 mb-12 max-w-2xl">A full range of treatments, delivered with care.</p>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {% for service in services %}
    <div class="bg-white border border-slate-200 rounded-xl p-6 hover:shadow-md transition-shadow">
      <div class="w-12 h-12 bg-primary/10 text-primary rounded-lg flex items-center justify-center mb-4">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/></svg>
      </div>
      <h3 class="font-semibold text-lg mb-2">{{ service }}</h3>
      <p class="text-sm text-slate-600">Comprehensive care, tailored to your needs.</p>
    </div>
    {% endfor %}
  </div>
</section>

<!-- About -->
<section id="about" class="bg-slate-50 py-20">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-6 text-primary">Why our patients keep coming back</h2>
    <p class="text-lg text-slate-600 leading-relaxed mb-4">
      We believe healthcare should feel personal. Short waits, clear explanations, and treatments built around your lifestyle — not the other way around.
    </p>
    <p class="text-slate-500 italic">— The team at {{ name }}</p>
  </div>
</section>

<!-- Booking -->
<section class="max-w-3xl mx-auto px-6 py-20 text-center">
  <h2 class="text-3xl md:text-4xl font-bold mb-3 text-primary">Book your appointment</h2>
  <p class="text-slate-600 mb-8">Online booking, no phone tag.</p>
  <div class="bg-white rounded-xl p-8 border border-slate-200 shadow-sm">
    <p class="text-slate-500 mb-4 text-sm">[ Cal.com booking widget would go here ]</p>
    <a href="tel:{{ phone }}" class="block w-full bg-primary text-white px-6 py-4 rounded-lg font-semibold text-lg hover:opacity-90">
      Or call: {{ phone or "—" }}
    </a>
  </div>
</section>

<!-- Visit -->
<section id="visit" class="bg-slate-50 py-20">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12">
    <div>
      <h2 class="text-3xl font-bold mb-6 text-primary">Visit us</h2>
      {% if address %}
      <p class="mb-3"><span class="font-semibold">Address:</span> {{ address }}</p>
      {% endif %}
      {% if phone %}
      <p class="mb-3"><span class="font-semibold">Phone:</span> <a href="tel:{{ phone }}" class="text-primary hover:underline">{{ phone }}</a></p>
      {% endif %}
      {% if google_maps_url %}
      <p class="mb-3"><a href="{{ google_maps_url }}" target="_blank" rel="noreferrer" class="text-accent hover:underline">→ Open in Google Maps</a></p>
      {% endif %}
    </div>
    <div>
      <h3 class="text-xl font-semibold mb-4 text-primary">Hours</h3>
      <ul class="space-y-2">
        {% for day, range in hours.items() %}
        <li class="flex justify-between border-b border-slate-200 pb-2">
          <span class="font-medium">{{ day }}</span>
          <span class="text-slate-600">{{ range }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

<footer class="bg-primary text-white py-8 text-center">
  <p class="text-sm opacity-90">© {{ name }}. All rights reserved.</p>
  <p class="text-xs opacity-60 mt-1">Demo built by your future web partner. <a href="https://the2357.com" class="underline hover:opacity-80">the2357.com</a></p>
</footer>

</body>
</html>
